# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://www.db360app.it"

# Stripe Publishable Key: Used for processing payments on the client side.
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Secret Key: Used on the server side to create payment intents.
# CRITICAL: This is a secret and should never be prefixed with VITE_.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Firebase VAPID Key: Required for web push notifications.
VITE_FIREBASE_VAPID_KEY="BN..."

# reCAPTCHA Enterprise Site Key
VITE_RECAPTCHA_SITE_KEY="your_recaptcha_site_key"

# Error Tracking & Analytics
VITE_SENTRY_DSN=""
VITE_MIXPANEL_TOKEN=""
