# --- Client (Vite: exposed to browser, prefix VITE_) ---

# App URL (OAuth return links, marketing)
VITE_APP_URL="https://www.db360app.it"

# Video landing opzionale (URL mp4 ciclismo verticale 9:16). Senza: animazione bici integrata.
# VITE_LANDING_VIDEO_URL="https://tu-storage/landing-bici.mp4"

# OAuth client (Google Cloud Console) — Origini JavaScript autorizzate consigliate:
#   http://localhost, http://localhost:5173, http://localhost:5000
#   https://doctorbike-v2.web.app, https://doctorbike-v2.firebaseapp.com
#   https://www.db360app.it, https://db360app.it
# URI di reindirizzamento (Firebase Auth) per ogni dominio usato:
#   https://<dominio>/__/auth/handler
# Firebase Auth → Impostazioni → Domini autorizzati: stessi host senza https

# Stripe publishable key (client)
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Firebase web app config (Firebase Console > Project settings)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# Cloud Functions region (default europe-west1)
VITE_FIREBASE_FUNCTIONS_REGION="europe-west1"
# Optional override for all function URLs:
# VITE_FUNCTIONS_BASE_URL="https://europe-west1-your-project.cloudfunctions.net"

# Web push (Firebase Console > Cloud Messaging > Web Push certificates)
VITE_FIREBASE_VAPID_KEY=""

# reCAPTCHA Enterprise (App Check) — Firebase Console → App Check → Enterprise
VITE_RECAPTCHA_SITE_KEY=""
VITE_APP_CHECK_ENABLED="true"
# Set true in dev to use debug token (register in App Check → Manage debug tokens)
VITE_APP_CHECK_DEBUG="false"

# Optional observability
VITE_SENTRY_DSN=""
VITE_MIXPANEL_TOKEN=""

# --- Server only (Cloud Functions: functions/.env, never VITE_) ---

# Gemini AI (Bike Doctor — solo server, non esporre al client)
GEMINI_API_KEY="your_gemini_api_key"

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
APP_URL="https://www.db360app.it"
MAIL_USER=""
MAIL_PASS=""
