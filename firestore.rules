rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN') ||
        (request.auth.token.email != null && (
          request.auth.token.email.lower() == 'doctorbike34@gmail.com' ||
          request.auth.token.email.lower() == 'doctorbike@gmail.com' ||
          request.auth.token.email.lower() == 'doctorbike@email.it'
        ))
      );
    }
    function isVerified() { 
      return isSignedIn(); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'createdAt']) &&
             data.uid is string &&
             data.role in ['CYCLIST', 'MECHANIC', 'ADMIN', 'PEER_MECHANIC'] &&
             (data.createdAt == request.time || data.createdAt is timestamp);
    }

    function isValidMechanic(data) {
      return data.keys().hasAll(['userId', 'isAvailable', 'businessName']) &&
             data.userId is string &&
             data.businessName is string;
    }

    function isValidSOS(data) {
      return data.keys().hasAll(['cyclistId', 'faultType', 'status', 'createdAt']) &&
             data.cyclistId == request.auth.uid &&
             data.status == 'PENDING' &&
             data.faultType is string;
    }

    function isValidRoadReport(data) {
      return data.keys().hasAll(['reporterId', 'reporterName', 'category', 'description', 'severity', 'location', 'status', 'upvotes', 'createdAt', 'updatedAt']) &&
             data.reporterId == request.auth.uid &&
             data.category in ['pothole', 'damaged_path', 'blocked_way', 'accident', 'bad_lighting', 'vandalism', 'obstacle', 'missing_signage', 'flooding', 'other'] &&
             data.severity in ['low', 'medium', 'high'] &&
             data.status in ['open', 'confirmed', 'in_review', 'resolved', 'rejected'] &&
             data.location.lat is number && data.location.lng is number;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      
      // Security Logic:
      // - Normal updates: Owners can update their profile (except role, balance, lastTxId, peerMechanicEarnings).
      // - Sent P2P: Owner can update balance + lastTxId IF their balance decreases and a valid transaction is created.
      // - Receive P2P: Any user can update another's balance + lastTxId IF their balance increases and a valid transaction is created.
      // - Admin has full control.
      allow update: if isAdmin() || (
        isOwner(userId) && (
          // Normal profile update
          (!incoming().diff(existing()).affectedKeys().hasAny(['role', 'balance', 'lastTxId', 'peerMechanicEarnings']) || (incoming().diff(existing()).affectedKeys().hasOnly(['role']) && incoming().role in ['CYCLIST', 'MECHANIC', 'PEER_MECHANIC']))
          ||
          // Balance change (Send P2P, TopUp, Escrow Refund, etc.)
          (
             (incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'updatedAt', 'lastTxId']) ||
              incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'updatedAt', 'lastTxId', 'firstInterventionDiscount'])) &&
             incoming().lastTxId is string &&
             existsAfter(/databases/$(database)/documents/transactions/$(incoming().lastTxId)) &&
             (
               (incoming().get('balance', 0) > existing().get('balance', 0) &&
                getAfter(/databases/$(database)/documents/transactions/$(incoming().lastTxId)).data.toId == userId &&
                getAfter(/databases/$(database)/documents/transactions/$(incoming().lastTxId)).data.amount == (incoming().get('balance', 0) - existing().get('balance', 0)))
               ||
               (incoming().get('balance', 0) < existing().get('balance', 0) &&
                getAfter(/databases/$(database)/documents/transactions/$(incoming().lastTxId)).data.fromId == userId &&
                getAfter(/databases/$(database)/documents/transactions/$(incoming().lastTxId)).data.amount == (existing().get('balance', 0) - incoming().get('balance', 0)))
             )
          )
        )
      ) || (
        // Receive P2P or Escrow Release
        isSignedIn() && (!isOwner(userId)) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'updatedAt', 'lastTxId', 'peerMechanicEarnings', 'peerMechanicJobsCompleted', 'points', 'weeklyPoints', 'badges']) &&
          (incoming().diff(existing()).affectedKeys().hasAny(['balance', 'lastTxId']) ? (
              incoming().get('balance', 0) >= existing().get('balance', 0) &&
              incoming().lastTxId is string &&
              existsAfter(/databases/$(database)/documents/transactions/$(incoming().lastTxId)) &&
              getAfter(/databases/$(database)/documents/transactions/$(incoming().lastTxId)).data.amount == (incoming().get('balance', 0) - existing().get('balance', 0)) &&
              getAfter(/databases/$(database)/documents/transactions/$(incoming().lastTxId)).data.toId == userId
          ) : true)
        )
      );
      allow delete: if isAdmin();
    }

    match /mechanics/{mechId} {
      allow read: if isSignedIn();
      allow create: if isOwner(mechId) && isValidMechanic(incoming());
      allow update: if isAdmin() || isOwner(mechId) || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['totalEarnings', 'completedJobs', 'updatedAt']));
      allow delete: if isAdmin();
    }

    match /platformStats/{statId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /aiConfig/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sosRequests/{sosId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidSOS(incoming());
      allow update: if isAdmin() || (isSignedIn() && (
        (existing().status == 'PENDING' && incoming().status == 'ACCEPTED' && incoming().mechanicId == request.auth.uid) ||
        (isOwner(existing().cyclistId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'description', 'photos', 'isReviewed', 'mechanicConfirmed', 'updatedAt', 'paymentStatus', 'cyclistConfirmed', 'completedAt', 'platformFee', 'mechanicNet', 'finalPrice', 'releaseTxId']) &&
         (incoming().get('paymentStatus', '') == 'RELEASED' ? (
             incoming().releaseTxId is string &&
             existsAfter(/databases/$(database)/documents/transactions/$(incoming().releaseTxId))
         ) : true)
        ) ||
        (isOwner(existing().mechanicId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'mechanicConfirmed', 'updatedAt', 'acceptedAt']))
      ));
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      // Allow read/write if the user is a participant (either existing or being added) or if it's a new chat they are creating
      allow read, write: if isSignedIn() && (
        isAdmin() || 
        (resource != null && request.auth.uid in resource.data.participants) ||
        (request.resource != null && request.auth.uid in request.resource.data.participants) ||
        // Fallback for list/get if the doc doesn't exist yet but user is about to be one
        (chatId.startsWith('direct_') && chatId.matches('.*' + request.auth.uid + '.*'))
      );

      match /messages/{msgId} {
        allow read, write: if isSignedIn(); 
      }
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().organizerId == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(existing().organizerId) || incoming().diff(existing()).affectedKeys().hasOnly(['participants', 'participantCount'])) || isAdmin();
      allow delete: if isOwner(existing().organizerId) || isAdmin();
    }

    match /roadReports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (
        isOwner(existing().reporterId) || 
        incoming().diff(existing()).affectedKeys().hasOnly(['upvotes', 'updatedAt'])
      ));
      allow delete: if isAdmin();
    }

    match /supportTickets/{ticketId} {
       allow create: if isSignedIn() && incoming().userId == request.auth.uid;
       allow read, update: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
       allow delete: if isAdmin();

       match /messages/{msgId} {
         allow read, create: if isSignedIn() && (get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.userId == request.auth.uid || isAdmin());
         allow delete: if isAdmin();
       }
    }

    match /aiConversations/{convId} {
       allow create: if isSignedIn() && incoming().userId == request.auth.uid;
       allow read, update: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
       allow delete: if isAdmin();
    }

    match /transactions/{txId} {
       // Users can read their own transactions
       allow read: if isAdmin() || (isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid || resource.data.userId == request.auth.uid));
       allow delete: if isAdmin();
       
       // Simplified creation: trust the users rule to cross-check the balance change
       // This breaks the getAfter circular dependency that causes failed-precondition
       allow create: if isSignedIn() && (
         incoming().fromId == request.auth.uid || 
         incoming().toId == request.auth.uid || 
         incoming().type == 'TOPUP' ||
         isAdmin()
       ) && incoming().amount >= 0;
    }

    match /interventions/{intId} {
       allow read: if isAdmin() || (isSignedIn() && (resource.data.cyclistId == request.auth.uid || resource.data.mechanicId == request.auth.uid));
       allow create: if isSignedIn() && (incoming().cyclistId == request.auth.uid || incoming().mechanicId == request.auth.uid);
       allow update: if isAdmin() || (isSignedIn() && (
         existing().cyclistId == request.auth.uid || existing().mechanicId == request.auth.uid
       ) && incoming().diff(existing()).affectedKeys().hasOnly(['aiDiagnosis']));
       allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn() && isOwner(incoming().cyclistId) && 
                      exists(/databases/$(database)/documents/sosRequests/$(incoming().sosRequestId));
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow create: if isSignedIn() && request.auth.token.email.lower() == 'doctorbike34@gmail.com';
      allow write: if isAdmin(); // Admins can manage other admins
    }
  }
}
